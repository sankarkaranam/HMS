{
  "name": "@clinic/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "express": "^5.0.1",
    "@types/express": "^5.0.0",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1",
    "@types/pg": "^8.11.10",
    "bullmq": "^5.34.5",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "zod": "^3.24.1",
    "nodemailer": "^6.9.16",
    "@types/nodemailer": "^6.4.17",
    "razorpay": "^2.9.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "uuid": "^11.0.5",
    "@types/uuid": "^10.0.0",
    "dotenv": "^16.4.7",
    "cors": "^2.8.5",
    "@types/cors": "^2.8.17",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.5.0",
    "morgan": "^1.10.0",
    "@types/morgan": "^1.9.9",
    "winston": "^3.17.0",
    "node-cron": "^3.0.3",
    "@types/node-cron": "^3.0.11"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "drizzle-kit": "^0.30.1",
    "vitest": "^2.1.8",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
