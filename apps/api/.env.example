# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://clinic_user:clinic_pass@localhost:5433/clinic_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets (generate with: openssl rand -base64 64) ────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-clinic-email@gmail.com
SMTP_PASS=your_gmail_app_password

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ─── Encryption (for gateway keys stored in DB) ───────────────────────────────
ENCRYPTION_KEY=change_me_32_char_encryption_key_here

# ─── PhonePe V2 API (OAuth2 - Test/Sandbox Mode) ──────────────────────────────
PHONEPE_CLIENT_ID=your_phonepe_client_id
PHONEPE_CLIENT_SECRET=your_phonepe_client_secret
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=production
BACKEND_API_URL=http://localhost:4000

# ─── Super Admin (Global SaaS Admin) ──────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@clinicbook.com
SUPER_ADMIN_PASSWORD=change_me_strong_password_here
