# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://clinic_user:clinic_pass@localhost:5432/clinic_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets (generate with: openssl rand -base64 64) ────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-clinic-email@gmail.com
SMTP_PASS=your_gmail_app_password  # Generate at myaccount.google.com/apppasswords

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Razorpay (Optional for Phase 1 — each clinic configures their own) ──────
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...

# ─── Encryption (for gateway keys stored in DB) ───────────────────────────────
ENCRYPTION_KEY=change_me_32_char_encryption_key  # AES-256 needs exactly 32 chars

# ─── PhonePe ──────────────────────────────────────────────────────────────────
PHONEPE_MERCHANT_ID=M23667ZTWVUU4_2602051256
PHONEPE_SALT_KEY=96434309-7796-489d-8924-ab56988a6076
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=uat
BACKEND_API_URL=http://localhost:4000
